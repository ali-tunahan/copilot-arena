{
  "name": "myext",
  "displayName": "MyExt Kod Düzenleyici",
  "publisher": "myext",
  "repository": {
    "type": "git",
    "url": "https://github.com/myext/myext"
  },
  "description": "İki farklı LLM prompt formatını yan yana karşılaştıran VS Code ders demo uzantısı",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "MyExt Kod Düzenleyici",
      "properties": {
        "myext.apiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "markdownDescription": "OpenAI uyumlu chat completions endpoint'inin kök URL'i (ör. `https://api.openai.com/v1`)."
        },
        "myext.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "markdownDescription": "Kullanılacak model adı (ör. fine-tuned model ID'niz)."
        },
        "myext.requestTimeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "markdownDescription": "Model isteği zaman aşımı (milisaniye)."
        }
      }
    },
    "commands": [
      {
        "command": "myext.promptToDiff",
        "title": "MyExt: Koddan Düzenleme Oluştur"
      },
      {
        "command": "myext.acceptFirstLLMResponse",
        "title": "MyExt: A Yanıtını Kabul Et (Arama & Değiştirme)"
      },
      {
        "command": "myext.acceptSecondLLMResponse",
        "title": "MyExt: B Yanıtını Kabul Et (Tüm Dosya)"
      },
      {
        "command": "myext.rejectAllResponses",
        "title": "MyExt: Tüm Yanıtları Reddet"
      },
      {
        "command": "myext.setApiKey",
        "title": "MyExt: API Anahtarını Ayarla"
      }
    ],
    "keybindings": [
      {
        "command": "myext.promptToDiff",
        "key": "cmd+i",
        "mac": "cmd+i",
        "win": "ctrl+i",
        "linux": "ctrl+i",
        "when": "editorTextFocus"
      },
      {
        "command": "myext.acceptFirstLLMResponse",
        "key": "cmd+1",
        "mac": "cmd+1",
        "win": "ctrl+1",
        "linux": "ctrl+1",
        "when": "editorTextFocus"
      },
      {
        "command": "myext.acceptSecondLLMResponse",
        "key": "cmd+2",
        "mac": "cmd+2",
        "win": "ctrl+2",
        "linux": "ctrl+2",
        "when": "editorTextFocus"
      },
      {
        "command": "myext.rejectAllResponses",
        "key": "cmd+3",
        "mac": "cmd+3",
        "win": "ctrl+3",
        "linux": "ctrl+3",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "compile-dev": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "test": "echo 'No tests configured'"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.3"
  },
  "dependencies": {}
}
